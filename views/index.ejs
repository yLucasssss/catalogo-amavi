<%- include('partials/header') %>

<h1 class="text-start">Catálago Amavi: Brilhe com a gente</h1>

<div class="mb-4 mt-4">
  <label for="filterTipo" class="form-label visually-hidden">Filtrar por Tipo</label>
  <select class="form-select" id="filterTipo" onchange="location = this.value;">
    <option value="/" <%= typeof selectedType === 'undefined' || selectedType === '' ? 'selected' : '' %>>Todos</option>
    <option value="/?tipo=Anel" <%= typeof selectedType !== 'undefined' && selectedType === 'Anel' ? 'selected' : '' %>>Anel</option>
    <option value="/?tipo=Colar" <%= typeof selectedType !== 'undefined' && selectedType === 'Colar' ? 'selected' : '' %>>Colar</option>
    <option value="/?tipo=Pulseira" <%= typeof selectedType !== 'undefined' && selectedType === 'Pulseira' ? 'selected' : '' %>>Pulseira</option>
    <option value="/?tipo=Berloque" <%= typeof selectedType !== 'undefined' && selectedType === 'Berloque' ? 'selected' : '' %>>Berloque</option>
    <option value="/?tipo=Piercing" <%= typeof selectedType !== 'undefined' && selectedType === 'Piercing' ? 'selected' : '' %>>Piercing</option>
    <option value="/?tipo=Brinco" <%= typeof selectedType !== 'undefined' && selectedType === 'Brinco' ? 'selected' : '' %>>Brinco</option>
    <option value="/?tipo=Trio" <%= typeof selectedType !== 'undefined' && selectedType === 'Trio' ? 'selected' : '' %>>Trio</option>
    <option value="/?tipo=Bracelete" <%= typeof selectedType !== 'undefined' && selectedType === 'Bracelete' ? 'selected' : '' %>>Bracelete</option>
  </select>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
  <% if (typeof pecas !== 'undefined' && pecas.length > 0) { %>
    <% pecas.forEach(peca => { %>
      <div class="col">
        <div class="card h-100 <%= peca.status === 'esgotado' ? 'sold-out-card' : '' %>" data-bs-toggle="modal" data-bs-target="#detailModal_<%= peca.id %>">
          <img src="<%= peca.imagem %>" class="card-img-top" alt="<%= peca.nome %>">
          <% if (peca.status === 'esgotado') { %>
            <div class="sold-out-overlay">
              <span class="sold-out-text">ESGOTADO</span>
            </div>
          <% } %>
          <div class="card-body">
            <h5 class="card-title"><%= peca.nome %></h5>
            <p class="card-text price-text">R$ <%= peca.preco.toFixed(2) %></p>
            <% if (peca.status === 'esgotado') { %>
              <p class="card-text availability-text sold-out">ESGOTADO</p>
            <% } %>
            <% if (peca.tipo === 'Anel') { %>
              <p class="card-text size-text">Tamanho: <%= peca.tamanho %></p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Modal -->
      <div class="modal fade" id="detailModal_<%= peca.id %>" tabindex="-1" aria-labelledby="detailModalLabel_<%= peca.id %>" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="detailModalLabel_<%= peca.id %>"><%= peca.nome %></h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="row">
                <div class="col-md-6">
                  <img src="<%= peca.imagem %>" class="img-fluid rounded" alt="<%= peca.nome %>">
                </div>
                <div class="col-md-6">
                  <h3>R$ <%= peca.preco.toFixed(2) %></h3>
                  <% if (peca.status === 'esgotado') { %>
                    <p class="lead text-danger"><br>&#9888; Essa peça linda está fora de estoque no momento, mas podemos fazer o pedido especialmente pra você com todo carinho! 💖</p>
                  <% } else { %>
                    <p class="lead text-success">Disponível</p>
                  <% } %>
                  <% if (peca.tipo === 'Anel') { %>
                    <p><strong>Tamanho:</strong> <%= peca.tamanho %></p>
                  <% } %>
                  <p><strong>Tipo:</strong> <%= peca.tipo %></p>
                  <a href="https://wa.me/5535998818786?text=<%= encodeURIComponent(peca.disponibilidade === 'esgotado' ? `Oii Estava vendo o catálogo e me apaixonei pela peça "${peca.nome}"\nSei que ela está esgotada no momento, mas posso encomendar especialmente pra mim? Quero garantir a minha! Como faço pra encomendar?` : `Oii, estava vendo o catálogo e me apaixonei pela peça "${peca.nome}"\nJa quero garantir a minha! Como faço pra comprar?`) %>" target="_blank" class="btn btn-buy-custom mt-3"><i class="fas fa-shopping-cart"></i> <%= peca.disponibilidade === 'esgotado' ? 'Encomendar' : 'Comprar' %></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  <% } else { %>
    <p>Nenhuma peça cadastrada.</p>
  <% } %>
</div>

<%- include('partials/footer') %>